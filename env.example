# =============================================================================
# .env.example – Vorlage für die Pi-Konfiguration
# Diese Datei ist SICHER für Git – sie enthält keine echten Secrets!
# bootstrap.sh kopiert sie zu ~/pi-admin/.env und fragt nach den echten Werten.
# =============================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN="DEIN_BOT_TOKEN_HIER"
TELEGRAM_CHAT_ID="DEINE_CHAT_ID_HIER"

# --- Verzeichnisse ---
PI_ADMIN_DIR="$HOME/pi-admin"
BACKUP_DIR="$HOME/backup"
DOCKER_DIR="$HOME/docker"

# --- Monitoring Schwellwerte ---
CPU_WARN=80
RAM_WARN=85
TEMP_WARN=70
DISK_WARN=85

# --- Backup ---
BACKUP_MAX_AGE_DAYS=30

# --- Logging ---
LOG_MAX_AGE_DAYS=60

# --- pi-home Profil ---
SYNC_DIR=/"$HOME/sync"


# --- Vaultwarden ---
PI_HOME_IP=192.168.1.x         # IP des pi-home
VW_ADMIN_TOKEN=                # openssl rand -base64 48 (leer = Admin-Panel deaktiviert)
